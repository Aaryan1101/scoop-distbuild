{
  "version": "1.1.4",
  "description": "Distributed Java build system. Speeds up Gradle builds by distributing compilation tasks across multiple machines on your local network.",
  "homepage": "https://github.com/Aaryan1101/distbuild",
  "license": "Apache-2.0",
  "architecture": {
    "64bit": {
      "url": "https://github.com/Aaryan1101/distbuild/releases/download/v1.1.4/distbuild-1.1.4.jar",
"hash": "sha256:2f31f9a642557857796a4029a0f3835910f7e6111b0528e05d55dc9b037cdc59"
    }
  },
  "extract_dir": "",
  "bin": "distbuild.bat",
  "post_install": [
    "# Create distbuild.bat launcher",
    "$dir = $original_dir",
    "$jar = Get-ChildItem $dir -Filter \"distbuild-*.jar\" | Select-Object -First 1",
    "$bin = \"$dir\\distbuild.bat\"",
    "",
    "New-Item -Path $bin -Value \"@echo off`r`nsetlocal`r`nset DISTBUILD_JVM_OPTS=-Xmx512m`r`njava %DISTBUILD_JVM_OPTS% -jar `\"$($jar.FullName)`\" %*`r`nendlocal\" -Force"
  ],
  "suggest": {
    "java": "java/openjdk",
    "redis": "redis-64"
  },
  "checkver": {
    "github": "Aaryan1101/distbuild",
    "regex": "v(\\d+\\.\\d+\\.\\d+)"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/Aaryan1101/distbuild/releases/download/v$matchHead/distbuild-$matchHead.jar"
      }
    },
    "hash": {
      "url": "https://github.com/Aaryan1101/distbuild/releases/download/v$matchHead/distbuild-$matchHead.jar.sha256"
    }
  }
}
